{
  "platform": "web",
  "stack": "react",
  "designSource": {
    "type": "storybook",
    "path": "src/Sideport.Admin/.storybook",
    "url": "https://dragoshont.github.io/sideport/",
    "spec": "docs/ui/sideport-ui-design-spec.md"
  },
  "knowledgePack": "web",
  "applyTo": [
    "src/Sideport.Admin/**",
    "docs/ui/**"
  ],
  "backend": {
    "stack": "dotnet",
    "solution": "Sideport.slnx",
    "architectureDocs": [
      "docs"
    ],
    "applyTo": [
      "src/**",
      "tests/**"
    ],
    "build": "dotnet build Sideport.slnx",
    "test": "dotnet test Sideport.slnx"
  },
  "iac": {
    "kind": "kubernetes",
    "path": "deploy",
    "plan": "kubectl kustomize deploy/k8s >/tmp/sideport-k8s-rendered.yaml && test -s /tmp/sideport-k8s-rendered.yaml",
    "policy": "kubectl kustomize deploy/k8s >/tmp/sideport-k8s-rendered.yaml && kubeconform -summary /tmp/sideport-k8s-rendered.yaml",
    "applyTo": [
      "deploy/**"
    ]
  },
  "ops": {
    "kind": "homelab-mcp",
    "mode": "read-only",
    "mcpServer": "homelab",
    "purpose": [
      "runtime-health",
      "logs",
      "deployment-verification",
      "version-drift"
    ],
    "requiresApprovalFor": [
      "mutations",
      "reconcile",
      "restart",
      "secret-access",
      "network-change"
    ]
  },
  "learning": {
    "runArtifactsPath": ".architrave/runs",
    "repoProfilePath": ".architrave/learning/repo-profile.md",
    "lessonsPath": ".architrave/learning/repo-lessons.md",
    "capture": [
      "run-artifacts",
      "gate-results",
      "judge-verdicts",
      "runtime-evidence",
      "repo-profile",
      "lessons"
    ],
    "redactionPolicy": "no-secrets",
    "staleFactPolicy": "validate-before-use",
    "promotionPolicy": "approval-required",
    "promoteAfterOccurrences": 2,
    "promoteTargets": [
      "architrave.config.json",
      "AGENTS.md",
      ".github/instructions",
      "docs"
    ]
  },
  "build": "npm --prefix src/Sideport.Admin run build",
  "test": "npm --prefix src/Sideport.Admin run lint",
  "screenshot": "npm --prefix src/Sideport.Admin run test:screens"
}
