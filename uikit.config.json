{
  "platform": "web",
  "stack": "react",
  "designSource": {
    "type": "storybook",
    "path": "src/Sideport.Admin/.storybook",
    "url": "https://dragoshont.github.io/sideport/",
    "spec": "docs/ui/sideport-ui-design-spec.md"
  },
  "knowledgePack": "web",
  "applyTo": [
    "src/Sideport.Admin/**",
    "docs/ui/**"
  ],
  "backend": {
    "stack": "dotnet",
    "solution": "Sideport.slnx",
    "architectureDocs": [
      "docs"
    ],
    "applyTo": [
      "src/**",
      "tests/**"
    ],
    "build": "dotnet build Sideport.slnx",
    "test": "dotnet test Sideport.slnx"
  },
  "iac": {
    "kind": "kubernetes",
    "path": "deploy",
    "plan": "kubectl kustomize deploy/k8s >/tmp/sideport-k8s-rendered.yaml && test -s /tmp/sideport-k8s-rendered.yaml",
    "policy": "kubectl kustomize deploy/k8s >/tmp/sideport-k8s-rendered.yaml && kubeconform -summary /tmp/sideport-k8s-rendered.yaml",
    "applyTo": [
      "deploy/**"
    ]
  },
  "build": "npm --prefix src/Sideport.Admin run build",
  "test": "npm --prefix src/Sideport.Admin run lint",
  "screenshot": "npm --prefix src/Sideport.Admin run test:screens"
}
