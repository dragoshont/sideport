# Copy to deploy/sideport.env. This example contains no usable secret.

# Pin an exact release or digest in production.
SIDEPORT_IMAGE=ghcr.io/dragoshont/sideport:0.1.12
ANISETTE_IMAGE=dadoum/anisette-v3-server:latest

# Generate once: openssl rand -hex 32
SIDEPORT_API_TOKEN=replace-with-a-random-token

# Native passkeys are the default and require no external identity service.
# Open SIDEPORT_PUBLIC_ORIGIN to create the first Owner passkey. Keep a fresh
# deployment loopback/LAN-only until it is claimed. To use a generic OIDC
# provider instead, set this to oidc and fill the OIDC values below.
SIDEPORT_IDENTITY_MODE=passkey
# SIDEPORT_OIDC_AUTHORITY=https://identity.example/application/o/sideport/
# SIDEPORT_OIDC_CLIENT_ID=sideport
# SIDEPORT_OIDC_CLIENT_SECRET=replace-from-your-secret-store
# SIDEPORT_IDENTITY_PROVIDER_LABEL=Company account
# SIDEPORT_IDENTITY_LOGIN_LABEL=Continue with Company SSO

# Stable Apple client identity used by the developer-services client. Generate
# once and preserve it with the Sideport and anisette backups: uuidgen
SIDEPORT_DEVICE_ID=00000000-0000-0000-0000-000000000000

# Loopback HTTP is accepted for first setup. Use a fixed HTTPS origin when
# exposing Sideport through a reverse proxy.
SIDEPORT_PUBLIC_ORIGIN=http://127.0.0.1:8080/
SIDEPORT_PORT=8080
SIDEPORT_INSTALL_TIMEOUT=00:03:00
SIDEPORT_INSTALL_CANCELLATION_GRACE=00:00:02
