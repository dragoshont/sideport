VITE_SIDEPORT_API_URL=/sideport-api
# Optional build-time token for local development only. The production Docker
# bundle does not bake secrets; use Settings > Browser API token in the portal.
VITE_SIDEPORT_API_TOKEN=
# Keep local/dev builds read-only unless you are deliberately exercising the live API mutation flow.
VITE_SIDEPORT_ENABLE_MUTATIONS=false